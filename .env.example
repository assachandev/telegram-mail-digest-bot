# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_USER_ID=123456789

# Gmail — files must exist inside HOST_DATA_DIR before running
GMAIL_CREDENTIALS_FILE=/data/credentials.json
GMAIL_TOKEN_FILE=/data/gmail_token.json

# Ollama — use any model pulled on your Ollama server (e.g. llama3.2:3b, qwen2.5:7b)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Bot
POLLING_INTERVAL_SECONDS=120

# Host path to mount as /data inside container
HOST_DATA_DIR=/path/to/data
